# StellarWork Frontend Environment Configuration
# Copy this file to .env.local and fill in the values.
#
# Required variables are marked with [REQUIRED].
# All variables are exposed to the browser via NEXT_PUBLIC_ prefix.

# [REQUIRED] Deployed escrow contract ID (starts with "C").
# Obtained from `soroban contract deploy` output.
NEXT_PUBLIC_CONTRACT_ID=

# Stellar network: "testnet" (default) or "mainnet".
# Controls network passphrase, explorer URLs, and RPC defaults.
NEXT_PUBLIC_NETWORK=testnet

# Soroban RPC endpoint URL.
# Defaults to the public Stellar testnet RPC when not set.
NEXT_PUBLIC_SOROBAN_RPC=https://soroban-testnet.stellar.org

# Default token contract address for the post-job form.
# Typically the Stellar native XLM asset contract address.
NEXT_PUBLIC_NATIVE_TOKEN=

# Admin wallet address (G...).
# When set, the Admin nav link and panel are visible only to this wallet.
# When unset, any connected wallet can access admin features.
NEXT_PUBLIC_ADMIN_ADDRESS=

# IPFS gateway URL for fetching job descriptions.
NEXT_PUBLIC_IPFS_GATEWAY_URL=https://dweb.link/ipfs/

# Web3.storage API token for uploading job descriptions to IPFS.
# When unset, descriptions are stored in localStorage only.
NEXT_PUBLIC_WEB3_STORAGE_TOKEN=
